    <ItemGroup>
      <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="11.0.0-preview.4.26230.115" />
    </ItemGroup>
    <ItemGroup>
        <!-- Replace "NameOfYourTargetAssembly" with the actual assembly name of the other DLL -->
        <InternalsVisibleTo Include="EntryPoint" />
    </ItemGroup>
    <ItemGroup>
      <Reference Include="0Harmony">
        <HintPath>..\Dependencies\0Harmony.dll</HintPath>
      </Reference>
      <Reference Include="AssetRipper.Primitives">
