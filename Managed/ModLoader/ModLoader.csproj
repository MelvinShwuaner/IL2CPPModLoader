      </Reference>
      <Reference Include="Il2CppInterop.StructGenerator">
        <HintPath>..\Dependencies\Il2CppInterop.StructGenerator.dll</HintPath>
      </Reference>
      <Reference Include="LibCpp2IL">
        <HintPath>..\Dependencies\LibCpp2IL.dll</HintPath>
      </Reference>
      <Reference Include="StableNameDotNet">
        <HintPath>..\Dependencies\StableNameDotNet.dll</HintPath>
      </Reference>
      <Reference Include="WasmDisassembler">
        <HintPath>..\Dependencies\WasmDisassembler.dll</HintPath>
      </Reference>
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="11.0.0-preview.4.26230.115" />
    </ItemGroup>

</Project>
