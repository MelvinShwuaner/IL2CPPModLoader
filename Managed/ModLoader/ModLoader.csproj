      </Reference>
      <Reference Include="Il2CppInterop.Runtime">
        <HintPath>..\Dependencies\Il2CppInterop.Runtime.dll</HintPath>
      </Reference>
      <Reference Include="LibCpp2IL">
        <HintPath>..\Dependencies\LibCpp2IL.dll</HintPath>
      </Reference>
      <Reference Include="Mono.Cecil">
        <HintPath>..\Dependencies\Mono.Cecil.dll</HintPath>
      </Reference>
      <Reference Include="MonoMod.Core">
